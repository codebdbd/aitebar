<local:DarkWindow x:Class="AiteBar.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AiteBar"
        Icon="pack://application:,,,/Resources/app.ico"
        Title="Настройки кнопки" Width="920" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" Background="#252525" Foreground="White"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True">
    
    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#252525" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#333333" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#555555" />
        
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#555555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4285F4"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                            <Path Fill="#AAAAAA" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" TextElement.Foreground="White"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#252525" BorderThickness="1" BorderBrush="#555555" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="8,0,8,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsEnabled" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#5C9AFF"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#7D7D7D"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20" x:Name="RootContentGrid" Grid.IsSharedSizeScope="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1.35*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Укажите имя для кнопки (обязательно):" Foreground="#AAA" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <TextBox x:Name="TxtName" TextChanged="TxtName_TextChanged"/>
                    <TextBlock x:Name="TxtNamePlaceholder" Margin="10,0,10,0" VerticalAlignment="Center" Foreground="#6F7782" IsHitTestVisible="False" Text="Например: Мой сайт, PowerShell, Скрипт" TextWrapping="NoWrap"/>
                </Grid>

                <TextBlock Text="В какой блок разместить кнопку?" Foreground="#AAA" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbBlock" Margin="0,0,0,15">
                    <ComboBoxItem Content="Блок 1: Нейросети" Tag="2"/>
                    <ComboBoxItem Content="Блок 2: Сайты" Tag="3"/>
                    <ComboBoxItem Content="Блок 3: Скрипты" Tag="4"/>
                    <ComboBoxItem Content="Блок 4: Другое" Tag="5"/>
                    <ComboBoxItem Content="Блок 5: Утилиты" Tag="1"/>
                </ComboBox>

                <TextBlock Text="Что будет делать кнопка?" Foreground="#AAA" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbActionType" Margin="0,0,0,15" SelectedIndex="0" SelectionChanged="CmbActionType_SelectionChanged">
                    <ComboBoxItem Content="Открывать URL сайта" Tag="Web"/>
                    <ComboBoxItem Content="Запускать программу" Tag="Exe"/>
                    <ComboBoxItem Content="Запускать скрипт (ps1, py)" Tag="ScriptFile"/>
                    <ComboBoxItem Content="Запускать консольную команду" Tag="Command"/>
                    <ComboBoxItem Content="Эмитировать нажатие клавиш" Tag="Hotkey"/>
                </ComboBox>

                <StackPanel x:Name="PanelStandardAction">
                <TextBlock x:Name="LblActionValue" Text="Вставьте URL сайта (обязательно):" Foreground="#AAA" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtActionValue" TextChanged="TxtActionValue_TextChanged"/>
                        <TextBlock x:Name="TxtActionPlaceholder" Margin="10,0,10,0" VerticalAlignment="Center" Foreground="#6F7782" IsHitTestVisible="False" TextWrapping="NoWrap"/>
                        <Button x:Name="BtnBrowse" Grid.Column="1" Width="100" Height="32" Margin="5,0,0,0" Click="BtnBrowse_Click" Visibility="Collapsed" Style="{StaticResource ActionButtonStyle}" Background="#444444" FontSize="12" FontWeight="Normal">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Обзор..." VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border x:Name="ActionHelpBox" Background="#252525" BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,15" Visibility="Collapsed">
                        <TextBlock x:Name="TxtActionHelp" Foreground="#9FA7B3" FontSize="11" TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel x:Name="PanelWebSettings">
                        <UniformGrid Columns="2">
                            <CheckBox x:Name="ChkAppMode" Content="Режим приложения" Foreground="White" Margin="0,5"/>
                            <CheckBox x:Name="ChkIncognito" Content="Инкогнито" Foreground="White" Margin="0,5"/>
                            <CheckBox x:Name="ChkTopmost" Content="Поверх всех окон" Foreground="White" Margin="0,5"/>
                            <CheckBox x:Name="ChkRotation" Content="Ротация профилей" Foreground="White" Margin="0,5"/>
                        </UniformGrid>
                        
                        <TextBlock Text="Выбрать профиль" Foreground="#AAA" Margin="10,10,0,5"/>
                        <ComboBox x:Name="CmbChromeProfile" Margin="0,0,0,15"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="PanelHotkeyAction" Visibility="Collapsed">
                <TextBlock Text="Настройте комбинацию (обязательно):" Foreground="#4285F4" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox x:Name="ChkCtrl" Content="Ctrl" Foreground="White" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                        <CheckBox x:Name="ChkShift" Content="Shift" Foreground="White" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                        <CheckBox x:Name="ChkAlt" Content="Alt" Foreground="White" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                        <CheckBox x:Name="ChkWin" Content="Win" Foreground="White" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Клавиша:" Foreground="#AAA" Margin="0,0,0,5" FontSize="11"/>
                    <ComboBox x:Name="CmbKey" Margin="0,0,0,15"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid x:Name="MiddleColumnGrid" Grid.Column="1" Margin="0,0,20,0" VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Выберите иконку:" Foreground="#AAA" Margin="0,0,0,5"/>
            <Border Grid.Row="1" Background="#252525" CornerRadius="8" BorderBrush="#444444" BorderThickness="1" Width="85" Height="85" HorizontalAlignment="Center" Margin="0,5,0,20">
                <Grid>
                    <TextBlock x:Name="PreviewIcon" Text="&#xEF0D;" FontSize="40" Foreground="#E3E3E3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Button Grid.Row="2" Style="{StaticResource ActionButtonStyle}" Background="#333333" Foreground="#E3E3E3" Height="36" FontSize="13" FontWeight="Normal" Margin="0,0,0,15" Click="BtnOpenCatalog_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE721;" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Выберите иконку" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <TextBlock Grid.Row="3" Text="Выбор цвета:" Foreground="#AAA" Margin="0,0,0,5"/>
            <UniformGrid x:Name="GridColors" Grid.Row="4" Columns="5" Margin="0,0,0,20"/>
            <Grid Grid.Row="5" Margin="0,0,0,19">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="HEX:" Foreground="#AAA" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="TxtHexColor" Grid.Column="1" Text="#E3E3E3" TextChanged="TxtHexColor_TextChanged"/>
            </Grid>

            <Button x:Name="BtnSave" Grid.Row="6" Style="{StaticResource ActionButtonStyle}" Height="36" FontSize="13" Click="BtnSave_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74E;" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Сохранить кнопку" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- CONTRACT: Right column height must always stay equal to MiddleColumnGrid height. -->
        <Grid Grid.Column="2" VerticalAlignment="Top" Height="{Binding ElementName=MiddleColumnGrid, Path=ActualHeight}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Порядок кнопок:" Foreground="#AAA" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbOrderBlock" Grid.Row="1" SelectionChanged="CmbOrderBlock_SelectionChanged" Margin="0,0,0,10">
                <ComboBoxItem Content="Блок 1: Нейросети" Tag="2"/>
                <ComboBoxItem Content="Блок 2: Сайты" Tag="3"/>
                <ComboBoxItem Content="Блок 3: Скрипты" Tag="4"/>
                <ComboBoxItem Content="Блок 4: Другое" Tag="5"/>
                <ComboBoxItem Content="Блок 5: Утилиты" Tag="1"/>
            </ComboBox>

            <ListBox x:Name="LstOrderButtons" Grid.Row="2" Background="#1F1F1F" BorderBrush="#444444" Foreground="White" Margin="0,0,0,10" SelectionChanged="LstOrderButtons_SelectionChanged"/>

            <UniformGrid Grid.Row="3" Columns="2" Margin="0,0,0,10">
                <Button x:Name="BtnMoveUp" Style="{StaticResource ActionButtonStyle}" Background="#333333" Foreground="#E3E3E3" Height="36" FontSize="13" FontWeight="Normal" Margin="0,0,4,0" Click="BtnMoveUp_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70E;" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Поднять" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnMoveDown" Style="{StaticResource ActionButtonStyle}" Background="#333333" Foreground="#E3E3E3" Height="36" FontSize="13" FontWeight="Normal" Margin="4,0,0,0" Click="BtnMoveDown_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70D;" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Опустить" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <Button x:Name="BtnSaveOrder" Grid.Row="4" Style="{StaticResource ActionButtonStyle}" Background="#333333" Foreground="#E3E3E3" Height="36" FontSize="13" FontWeight="Normal" Click="BtnSaveOrder_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74E;" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Сохранить порядок" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <TextBlock x:Name="TxtOrderStatus"
                       Grid.Row="5"
                       Margin="2,8,2,0"
                       Foreground="#9FA7B3"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"/>
        </Grid>
    </Grid>
</local:DarkWindow>
