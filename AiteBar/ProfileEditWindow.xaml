<local:DarkWindow x:Class="AiteBar.ProfileEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AiteBar"
        Title="Профиль" Width="400" Height="450"
        WindowStartupLocation="CenterOwner" Background="#1A1A1C" Foreground="White"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" ShowInTaskbar="False">
    <Border BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8" Background="#1A1A1C">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Настройки профиля" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Название" Foreground="#9BA1A6" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtName" Height="32" Background="#2D2D30" Foreground="White" BorderBrush="#3E3E42" Padding="5,0" VerticalContentAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Margin="0,0,20,0">
                    <TextBlock Text="Иконка" Foreground="#9BA1A6" Margin="0,0,0,5"/>
                    <Border x:Name="BorderPreview" Width="64" Height="64" Background="#2D2D30" CornerRadius="8" Cursor="Hand" MouseLeftButtonDown="BtnSelectIcon_Click">
                        <Grid>
                            <TextBlock x:Name="TxtPreviewIcon" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image x:Name="ImgPreview" Width="48" Height="48" Stretch="Uniform" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Цвет" Foreground="#9BA1A6" Margin="0,0,0,5"/>
                    <UniformGrid x:Name="GridColors" Columns="4"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Отмена" Width="80" Height="32" Margin="0,0,10,0" Click="BtnCancel_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                <Button Content="Готово" Width="100" Height="32" Click="BtnOk_Click" Style="{StaticResource ActionButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</local:DarkWindow>
