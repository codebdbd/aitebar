<local:DarkWindow x:Class="AiteBar.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AiteBar"
        Icon="pack://application:,,,/Resources/app.ico"
        Title="Порядок кнопок" Width="420" SizeToContent="Height" MinHeight="420"
        WindowStartupLocation="CenterOwner" Background="#1E1E1E" Foreground="White"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True">

    <Window.Resources>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#555555"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4285F4"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#E3E3E3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Блок:" Foreground="#AAA" Margin="0,0,0,6"/>
        <ComboBox x:Name="CmbOrderBlock" Grid.Row="1" Margin="0,0,0,10" SelectionChanged="CmbOrderBlock_SelectionChanged">
            <ComboBoxItem Content="Блок 1: Нейросети" Tag="2"/>
            <ComboBoxItem Content="Блок 2: Сайты" Tag="3"/>
            <ComboBoxItem Content="Блок 3: Скрипты" Tag="4"/>
            <ComboBoxItem Content="Блок 4: Другое" Tag="5"/>
            <ComboBoxItem Content="Блок 5: Утилиты" Tag="1"/>
        </ComboBox>

        <ListBox x:Name="LstOrderButtons" Grid.Row="2" Margin="0,0,0,10" Background="#1F1F1F" BorderBrush="#444444" Foreground="White"/>

        <UniformGrid Grid.Row="3" Columns="2" Margin="0,0,0,10">
            <Button x:Name="BtnMoveUp" Content="Поднять" Style="{StaticResource ActionButtonStyle}" Margin="0,0,4,0" Click="BtnMoveUp_Click"/>
            <Button x:Name="BtnMoveDown" Content="Опустить" Style="{StaticResource ActionButtonStyle}" Margin="4,0,0,0" Click="BtnMoveDown_Click"/>
        </UniformGrid>

        <Button x:Name="BtnSaveOrder" Grid.Row="4" Content="Сохранить порядок" Style="{StaticResource ActionButtonStyle}" Click="BtnSaveOrder_Click"/>
    </Grid>
</local:DarkWindow>
