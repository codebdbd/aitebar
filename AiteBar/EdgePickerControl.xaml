<UserControl x:Class="AiteBar.EdgePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="240"
             MinHeight="180">
    <Border Background="#202024" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8" Padding="10">
        <Grid x:Name="RootGrid" Background="Transparent" SizeChanged="RootGrid_SizeChanged">
            <Canvas x:Name="OverlayCanvas" Background="Transparent">
                <Border x:Name="MonitorFrame"
                        Background="#1A1A1C"
                        BorderBrush="#4B4B51"
                        BorderThickness="1"
                        CornerRadius="8"/>

                <Border x:Name="TopZone"
                        Background="Transparent"
                        Cursor="Hand"
                        Tag="Top"
                        MouseLeftButtonDown="EdgeZone_MouseLeftButtonDown"/>
                <Border x:Name="BottomZone"
                        Background="Transparent"
                        Cursor="Hand"
                        Tag="Bottom"
                        MouseLeftButtonDown="EdgeZone_MouseLeftButtonDown"/>
                <Border x:Name="LeftZone"
                        Background="Transparent"
                        Cursor="Hand"
                        Tag="Left"
                        MouseLeftButtonDown="EdgeZone_MouseLeftButtonDown"/>
                <Border x:Name="RightZone"
                        Background="Transparent"
                        Cursor="Hand"
                        Tag="Right"
                        MouseLeftButtonDown="EdgeZone_MouseLeftButtonDown"/>

                <Border x:Name="ActivationIndicator"
                        Background="#22007ACC"
                        BorderBrush="#66007ACC"
                        BorderThickness="1"
                        CornerRadius="4"
                        IsHitTestVisible="False"/>

                <Border x:Name="PanelIndicator"
                        Background="#007ACC"
                        CornerRadius="4"
                        Cursor="SizeAll"
                        MouseLeftButtonDown="PanelIndicator_MouseLeftButtonDown"/>

                <TextBlock x:Name="EdgeLabel"
                           Foreground="#DCDCDC"
                           FontSize="11"
                           FontWeight="SemiBold"
                           IsHitTestVisible="False"/>
            </Canvas>
        </Grid>
    </Border>
</UserControl>
