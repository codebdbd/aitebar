<local:DarkWindow x:Class="AiteBar.AppSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AiteBar"
        Icon="pack://application:,,,/Resources/app.ico"
        Title="Настройки программы" Width="420" MaxHeight="650"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner" Background="#252525" Foreground="White"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True">
    
    <Window.Resources>
        <local:FontNameConverter x:Key="FontNameConverter"/>
        <local:ColorBrushConverter x:Key="ColorBrushConverter"/>
        <local:ProfileIconConverter x:Key="ProfileIconConverter"/>
        
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4285F4"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="Bold" Foreground="#AAA" Margin="5,0"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5C9AFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <DockPanel>
            <Border DockPanel.Dock="Bottom" Background="#1A1A1A" Padding="20,10" BorderBrush="#33FFFFFF" BorderThickness="0,1,0,0">
                <Button Content="Сохранить настройки" Style="{StaticResource ActionButtonStyle}" Click="BtnSave_Click"/>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">
                    <GroupBox Header="ГОРЯЧИЕ КЛАВИШИ">
                        <StackPanel>
                            <TextBlock Text="Сочетание для вызова панели:" Foreground="#888" Margin="0,0,0,8" FontSize="11"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox x:Name="ChkCtrl" Content="Ctrl" Foreground="White" Margin="0,0,12,0" VerticalContentAlignment="Center"/>
                                <CheckBox x:Name="ChkShift" Content="Shift" Foreground="White" Margin="0,0,12,0" VerticalContentAlignment="Center"/>
                                <CheckBox x:Name="ChkAlt" Content="Alt" Foreground="White" Margin="0,0,12,0" VerticalContentAlignment="Center"/>
                                <CheckBox x:Name="ChkWin" Content="Win" Foreground="White" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <DockPanel>
                                <TextBlock Text="Клавиша:" Foreground="#AAA" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="CmbKey" Height="28"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="БЫСТРЫЕ ИНСТРУМЕНТЫ">
                        <UniformGrid Columns="2">
                            <CheckBox x:Name="ChkShowPresetSearch" Content="Поиск" Foreground="White" Margin="0,5" VerticalContentAlignment="Center"/>
                            <CheckBox x:Name="ChkShowPresetScreenshot" Content="Скриншот" Foreground="White" Margin="0,5" VerticalContentAlignment="Center"/>
                            <CheckBox x:Name="ChkShowPresetVideo" Content="Видео" Foreground="White" Margin="0,5" VerticalContentAlignment="Center"/>
                            <CheckBox x:Name="ChkShowPresetCalc" Content="Калькулятор" Foreground="White" Margin="0,5" VerticalContentAlignment="Center"/>
                        </UniformGrid>
                    </GroupBox>

                    <GroupBox Header="ЗОНА АКТИВАЦИИ">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Край экрана:" Foreground="#888" Margin="0,0,0,4" FontSize="11"/>
                                    <ComboBox x:Name="CmbEdge" Height="28">
                                        <ComboBoxItem Content="Сверху" Tag="Top"/>
                                        <ComboBoxItem Content="Снизу" Tag="Bottom"/>
                                        <ComboBoxItem Content="Слева" Tag="Left"/>
                                        <ComboBoxItem Content="Справа" Tag="Right"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Монитор:" Foreground="#888" Margin="0,0,0,4" FontSize="11"/>
                                    <ComboBox x:Name="CmbMonitor" Height="28"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Размер зоны (%):" Foreground="#888" Margin="0,0,0,2" FontSize="11"/>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock x:Name="TxtZoneSize" Text="30%" Foreground="White" Width="35" VerticalAlignment="Center" DockPanel.Dock="Right" TextAlignment="Right" FontSize="11"/>
                                <Slider x:Name="SldZoneSize" Minimum="5" Maximum="100" Value="30" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="SldZoneSize_ValueChanged"/>
                            </DockPanel>

                            <TextBlock Text="Задержка (мс):" Foreground="#888" Margin="0,0,0,2" FontSize="11"/>
                            <DockPanel>
                                <TextBlock x:Name="TxtDelay" Text="250" Foreground="White" Width="35" VerticalAlignment="Center" DockPanel.Dock="Right" TextAlignment="Right" FontSize="11"/>
                                <Slider x:Name="SldDelay" Minimum="0" Maximum="2000" Value="250" TickFrequency="50" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="SldDelay_ValueChanged"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="ПРОФИЛИ ПАНЕЛИ">
                        <StackPanel>
                            <Button Content="Добавить новый профиль" Style="{StaticResource ActionButtonStyle}" Background="#34A853" 
                                    Height="26" FontSize="11" Margin="0,0,0,10" Click="BtnAddProfile_Click"/>
                            
                            <ListBox x:Name="LstProfiles" Background="#151515" Foreground="White" BorderBrush="#33FFFFFF" Height="140">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Icon}" FontFamily="{Binding IconFont, Converter={StaticResource FontNameConverter}}" FontSize="14" Foreground="{Binding IconColor, Converter={StaticResource ColorBrushConverter}}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ImagePath}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Image Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Source">
                                                                <Setter.Value>
                                                                    <MultiBinding Converter="{StaticResource ProfileIconConverter}">
                                                                        <Binding Path="Icon"/>
                                                                        <Binding Path="IconFont"/>
                                                                        <Binding Path="ImagePath"/>
                                                                    </MultiBinding>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ImagePath}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                            </Grid>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" FontSize="12"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="&#xE70F;" FontFamily="Segoe MDL2 Assets" Background="Transparent" Foreground="#666" Margin="3,0" Width="24" Height="24" Click="BtnEditProfile_Click" Tag="{Binding}"/>
                                                <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Background="Transparent" Foreground="#844" Width="24" Height="24" Click="BtnDeleteProfile_Click" Tag="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</local:DarkWindow>
