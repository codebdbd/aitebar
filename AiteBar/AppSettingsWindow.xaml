<local:DarkWindow x:Class="AiteBar.AppSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AiteBar"
        Icon="pack://application:,,,/Resources/app.ico"
        Title="Настройки программы" Width="760" Height="690"
        WindowStartupLocation="CenterOwner" Background="#1A1A1C" Foreground="#DCDCDC"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True">
    
    <Window.Resources>
        <local:FontNameConverter x:Key="FontNameConverter"/>
        <local:ColorBrushConverter x:Key="ColorBrushConverter"/>

        <SolidColorBrush x:Key="PanelBackground" Color="#252526"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3E3E42"/>
        <SolidColorBrush x:Key="AccentColor" Color="#007ACC"/>
        <SolidColorBrush x:Key="MutedText" Color="#9BA1A6"/>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#454549"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                            <Setter Property="CornerRadius" Value="4,4,0,0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Path Fill="#AAAAAA" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="#252526" BorderThickness="1" BorderBrush="{StaticResource BorderColor}" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C97EA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="#717171"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#3E3E42"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4E4E52"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0,0,0"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>

        <Style x:Key="CompactCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Padding" Value="2,0,0,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,10,0">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="ПОЗИЦИЯ И РАЗМЕР" Foreground="{StaticResource MutedText}" FontWeight="Bold" FontSize="11" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Край экрана:" Foreground="{StaticResource MutedText}" Margin="0,0,0,5" FontSize="11"/>
                                <ComboBox x:Name="CmbEdge">
                                    <ComboBoxItem Content="Сверху" Tag="Top"/>
                                    <ComboBoxItem Content="Снизу" Tag="Bottom"/>
                                    <ComboBoxItem Content="Слева" Tag="Left"/>
                                    <ComboBoxItem Content="Справа" Tag="Right"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Монитор:" Foreground="{StaticResource MutedText}" Margin="0,0,0,5" FontSize="11"/>
                                <ComboBox x:Name="CmbMonitor"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Размер зоны активации:" Foreground="{StaticResource MutedText}" Margin="0,0,0,5" FontSize="11"/>
                        <TextBlock Text="% от ширины/высоты экрана" Foreground="{StaticResource MutedText}" Margin="0,0,0,5" FontSize="10"/>
                        <DockPanel Margin="0,0,0,15">
                            <TextBlock x:Name="TxtZoneSize" Text="30%" Foreground="White" Width="44" VerticalAlignment="Center" DockPanel.Dock="Right" TextAlignment="Right" FontSize="12"/>
                            <Slider x:Name="SldZoneSize" Minimum="5" Maximum="100" Value="30" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="SldZoneSize_ValueChanged"/>
                        </DockPanel>

                        <TextBlock Text="Размер панели:" Foreground="{StaticResource MutedText}" Margin="0,0,0,5" FontSize="11"/>
                        <TextBlock Text="% от ширины/высоты экрана" Foreground="{StaticResource MutedText}" Margin="0,0,0,5" FontSize="10"/>
                        <DockPanel Margin="0,0,0,15">
                            <TextBlock x:Name="TxtPanelSize" Text="80%" Foreground="White" Width="44" VerticalAlignment="Center" DockPanel.Dock="Right" TextAlignment="Right" FontSize="12"/>
                            <Slider x:Name="SldPanelSize" Minimum="20" Maximum="100" Value="80" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="SldPanelSize_ValueChanged"/>
                        </DockPanel>

                        <TextBlock Text="Задержка активации (мс):" Foreground="{StaticResource MutedText}" Margin="0,0,0,5" FontSize="11"/>
                        <DockPanel>
                            <TextBlock x:Name="TxtDelay" Text="250" Foreground="White" Width="44" VerticalAlignment="Center" DockPanel.Dock="Right" TextAlignment="Right" FontSize="12"/>
                            <Slider x:Name="SldDelay" Minimum="0" Maximum="2000" Value="250" TickFrequency="50" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="SldDelay_ValueChanged"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="Панель появляется по центру выбранного края. Размер зоны и размер панели считаются от активной оси экрана." Foreground="{StaticResource MutedText}" FontSize="10" TextWrapping="Wrap" Margin="4,0,8,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="ГОРЯЧИЕ КЛАВИШИ" Foreground="{StaticResource MutedText}" FontWeight="Bold" FontSize="11" Margin="0,0,0,12"/>
                        <TextBlock Text="Сочетание для вызова панели:" Foreground="{StaticResource MutedText}" Margin="0,0,0,8" FontSize="11"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <CheckBox x:Name="ChkCtrl" Content="Ctrl" Margin="0,0,15,0"/>
                            <CheckBox x:Name="ChkShift" Content="Shift" Margin="0,0,15,0"/>
                            <CheckBox x:Name="ChkAlt" Content="Alt" Margin="0,0,15,0"/>
                            <CheckBox x:Name="ChkWin" Content="Win"/>
                        </StackPanel>
                        <DockPanel>
                            <TextBlock Text="Клавиша:" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                            <ComboBox x:Name="CmbKey" Height="30"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="ГОРЯЧИЕ КЛАВИШИ КОНТЕКСТОВ" Foreground="{StaticResource MutedText}" FontWeight="Bold" FontSize="11" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Следующий" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="ChkNextContextCtrl" Content="Ctrl" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkNextContextShift" Content="Shift" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkNextContextAlt" Content="Alt" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkNextContextWin" Content="Win" Style="{StaticResource CompactCheckBoxStyle}"/>
                            </StackPanel>
                            <ComboBox x:Name="CmbNextContextKey" Grid.Column="2" Height="28"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Предыдущий" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="ChkPrevContextCtrl" Content="Ctrl" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkPrevContextShift" Content="Shift" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkPrevContextAlt" Content="Alt" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkPrevContextWin" Content="Win" Style="{StaticResource CompactCheckBoxStyle}"/>
                            </StackPanel>
                            <ComboBox x:Name="CmbPrevContextKey" Grid.Column="2" Height="28"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblContext1Hotkey" Text="Контекст 1" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="ChkContext1Ctrl" Content="Ctrl" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkContext1Shift" Content="Shift" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkContext1Alt" Content="Alt" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkContext1Win" Content="Win" Style="{StaticResource CompactCheckBoxStyle}"/>
                            </StackPanel>
                            <ComboBox x:Name="CmbContext1Key" Grid.Column="2" Height="28"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblContext2Hotkey" Text="Контекст 2" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="ChkContext2Ctrl" Content="Ctrl" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkContext2Shift" Content="Shift" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkContext2Alt" Content="Alt" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkContext2Win" Content="Win" Style="{StaticResource CompactCheckBoxStyle}"/>
                            </StackPanel>
                            <ComboBox x:Name="CmbContext2Key" Grid.Column="2" Height="28"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblContext3Hotkey" Text="Контекст 3" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="ChkContext3Ctrl" Content="Ctrl" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkContext3Shift" Content="Shift" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkContext3Alt" Content="Alt" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkContext3Win" Content="Win" Style="{StaticResource CompactCheckBoxStyle}"/>
                            </StackPanel>
                            <ComboBox x:Name="CmbContext3Key" Grid.Column="2" Height="28"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblContext4Hotkey" Text="Контекст 4" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox x:Name="ChkContext4Ctrl" Content="Ctrl" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkContext4Shift" Content="Shift" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkContext4Alt" Content="Alt" Style="{StaticResource CompactCheckBoxStyle}"/>
                                <CheckBox x:Name="ChkContext4Win" Content="Win" Style="{StaticResource CompactCheckBoxStyle}"/>
                            </StackPanel>
                            <ComboBox x:Name="CmbContext4Key" Grid.Column="2" Height="28"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="БЫСТРЫЕ ИНСТРУМЕНТЫ" Foreground="{StaticResource MutedText}" FontWeight="Bold" FontSize="11" Margin="0,0,0,12"/>
                        <UniformGrid Columns="2">
                            <CheckBox x:Name="ChkShowPresetSearch" Content="Поиск"/>
                            <CheckBox x:Name="ChkShowPresetScreenshot" Content="Скриншот"/>
                            <CheckBox x:Name="ChkShowPresetVideo" Content="Видео"/>
                            <CheckBox x:Name="ChkShowPresetCalc" Content="Калькулятор"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="КОНТЕКСТЫ" Foreground="{StaticResource MutedText}" FontWeight="Bold" FontSize="11" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="1" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="TxtContext1Name" Grid.Column="1" TextChanged="ContextName_TextChanged"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="2" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="TxtContext2Name" Grid.Column="1" TextChanged="ContextName_TextChanged"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="3" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="TxtContext3Name" Grid.Column="1" TextChanged="ContextName_TextChanged"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="4" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="TxtContext4Name" Grid.Column="1" TextChanged="ContextName_TextChanged"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Отмена" Style="{StaticResource SecondaryButtonStyle}" Click="BtnCancel_Click" Height="40" Width="130" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <Button Content="Сохранить" Style="{StaticResource ActionButtonStyle}" Click="BtnSave_Click" Height="40" Width="180" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</local:DarkWindow>
