<local:DarkWindow x:Class="SmartScreenDock.DarkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SmartScreenDock"
        Icon="pack://application:,,,/Resources/app.ico"
        Title="Внимание" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" Background="#1E1E1E" Foreground="White"
        WindowStyle="SingleBorderWindow" ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True">
    
    <Window.Resources>
        <Style x:Key="DialogBtnStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtMessage" Text="Сообщение" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnYes" Content="Да" Background="#4285F4" Style="{StaticResource DialogBtnStyle}" Click="BtnYes_Click" Visibility="Collapsed"/>
            <Button x:Name="BtnNo" Content="Отмена" Background="#333333" Style="{StaticResource DialogBtnStyle}" Click="BtnNo_Click" Visibility="Collapsed"/>
            <Button x:Name="BtnOk" Content="ОК" Background="#4285F4" Style="{StaticResource DialogBtnStyle}" Click="BtnOk_Click" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</local:DarkWindow>
