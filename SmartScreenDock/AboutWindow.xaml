<local:DarkWindow x:Class="SmartScreenDock.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SmartScreenDock"
        Icon="pack://application:,,,/Resources/app.ico"
        Title="О программе"
        Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="White"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B8B8B8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5A95F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#E3E3E3"/>
        </Style>

        <Style x:Key="InfoBoxStyle" TargetType="Border">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="AiteBar (Smart Control Panel)" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtVersion" Style="{StaticResource MutedTextStyle}" Margin="0,0,0,14"/>

            <TextBlock Style="{StaticResource MutedTextStyle}"
                       Text="Скрытая панель быстрого доступа для Windows. Позволяет запускать сайты, приложения, скрипты, команды и горячие клавиши из настраиваемых блоков."/>

            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Информация"/>
            <TextBlock Style="{StaticResource MutedTextStyle}" Text="Разработчик: Codebdbd"/>
            <TextBlock Style="{StaticResource MutedTextStyle}" Text="© 2026 Codebdbd"/>

            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Технологии"/>
            <TextBlock Style="{StaticResource MutedTextStyle}" Text=".NET 8"/>
            <TextBlock Style="{StaticResource MutedTextStyle}" Text="WPF"/>

            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Иконки"/>
            <TextBlock Style="{StaticResource MutedTextStyle}" Text="Fluent System Icons"/>
            <TextBlock Style="{StaticResource MutedTextStyle}" Text="Material Icons"/>
            <TextBlock Style="{StaticResource MutedTextStyle}" Text="Font Awesome Brands"/>

            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Данные приложения"/>
            <Border Style="{StaticResource InfoBoxStyle}">
                <TextBlock Text="AppData\Roaming\Codebdbd\Aite Bar" Style="{StaticResource MutedTextStyle}"/>
            </Border>

            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Исполняемый файл"/>
            <Border Style="{StaticResource InfoBoxStyle}">
                <TextBlock x:Name="TxtExePath" Style="{StaticResource MutedTextStyle}"/>
            </Border>
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,20,0,0">
            <Button Content="Страница программы" Style="{StaticResource PrimaryButtonStyle}" Click="BtnWebsite_Click"/>
            <Button Content="GitHub репозиторий" Style="{StaticResource SecondaryButtonStyle}" Click="BtnRepository_Click"/>
            <Button Content="Лицензии" Style="{StaticResource SecondaryButtonStyle}" Click="BtnLicenses_Click"/>
            <Button Content="Открыть папку" Style="{StaticResource SecondaryButtonStyle}" Click="BtnOpenFolder_Click"/>
        </WrapPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Закрыть" Width="90" Style="{StaticResource PrimaryButtonStyle}" Margin="0" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</local:DarkWindow>
